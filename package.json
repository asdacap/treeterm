{
  "name": "treeterm",
  "version": "0.1.0",
  "description": "Hierarchical terminal manager for AI agent workflows",
  "main": "./out/main/index.js",
  "bin": {
    "treeterm": "./bin/treeterm.js"
  },
  "files": [
    "bin",
    "out",
    "package.json"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "build": "npm run typecheck && npm run build:daemon && electron-vite build",
    "build:daemon": "tsc --project tsconfig.daemon.json",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/pino": "^7.0.4",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "eslint": "^9.39.4",
    "playwright": "^1.58.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.0.0",
    "lucide-react": "^0.577.0",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "node-pty": "^1.0.0",
    "openai": "^6.27.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "simple-git": "^3.32.3",
    "tinykeys": "^3.0.0",
    "zustand": "^5.0.0"
  }
}
