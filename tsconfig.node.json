{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "downlevelIteration": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "electron.vite.config.ts",
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "src/generated/**/*.ts",
    "src/renderer/types/**/*.ts",
    "src/renderer/store/createTtyStore.ts",
    "src/renderer/store/createAnalyzerStore.ts",
    "src/renderer/store/createWorkspaceStore.ts",
    "src/renderer/store/createSessionStore.ts"
  ]
}
